<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
  <title>DAZER</title>
  <link rel="manifest" href="data:application/json;base64,">
  <style>
    :root {
      --bg: #0a0a0a;
      --surface: #1a1a1a;
      --border: #333;
      --text: #f0f0f0;
      --muted: #777;
      --online: #2ecc71;
      --offline: #e74c3c;
      --radius: 8px;
      --nav-height: 64px;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Segoe UI', system-ui, sans-serif;
      height: 100vh;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      user-select: none;
      -webkit-tap-highlight-color: transparent;
    }
    .header {
      padding: 12px 16px;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
      min-height: 50px;
    }
    .logo {
      font-family: 'Impact', 'Arial Black', sans-serif;
      font-size: 28px;
      letter-spacing: 4px;
      color: #fff;
      text-shadow: 0 0 10px rgba(255,255,255,0.3);
    }
    .header-actions {
      display: flex;
      gap: 10px;
      align-items: center;
    }
    .icon-btn {
      background: none;
      border: 1px solid var(--border);
      color: var(--text);
      font-size: 16px;
      width: 36px;
      height: 36px;
      border-radius: 50%;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: 0.2s;
    }
    .icon-btn:hover { border-color: #fff; color: #fff; }
    .status-dot {
      width: 10px; height: 10px;
      border-radius: 50%;
      display: inline-block;
      margin-right: 6px;
    }
    .screen {
      display: none;
      flex-direction: column;
      flex: 1;
      overflow-y: auto;
      padding: 16px;
      -webkit-overflow-scrolling: touch;
    }
    .screen.active { display: flex; }
    .login-box, .master-box {
      max-width: 360px;
      margin: auto;
      background: var(--surface);
      border: 1px solid var(--border);
      padding: 30px;
      border-radius: var(--radius);
      display: flex;
      flex-direction: column;
      gap: 14px;
    }
    .input {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 12px;
      color: var(--text);
      font-size: 16px;
      outline: none;
      width: 100%;
    }
    .input:focus { border-color: #fff; }
    .btn {
      background: #fff;
      color: #000;
      border: none;
      border-radius: var(--radius);
      padding: 12px;
      font-weight: bold;
      font-size: 16px;
      cursor: pointer;
      transition: opacity 0.2s;
      letter-spacing: 1px;
    }
    .btn:hover { opacity: 0.85; }
    .btn.secondary {
      background: var(--surface);
      color: var(--text);
      border: 1px solid var(--border);
    }
    .error-msg {
      color: var(--offline);
      font-size: 13px;
      display: none;
      text-align: center;
    }
    .nav-bar {
      display: flex;
      background: var(--surface);
      border-top: 1px solid var(--border);
      height: var(--nav-height);
      align-items: center;
      justify-content: space-around;
    }
    .nav-item {
      background: none;
      border: none;
      color: var(--muted);
      font-size: 12px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
      cursor: pointer;
      padding: 8px 12px;
      letter-spacing: 1px;
      transition: 0.2s;
    }
    .nav-item.active { color: #fff; border-bottom: 2px solid #fff; }
    .nav-item:hover { color: #fff; }
    .user-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 14px;
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 10px;
      cursor: pointer;
      transition: 0.2s;
    }
    .user-card:hover { border-color: #fff; }
    .user-avatar {
      width: 40px; height: 40px;
      border-radius: 50%;
      background: #2a2a2a;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: bold;
      font-size: 18px;
      color: #fff;
    }
    .grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }
    .content-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      aspect-ratio: 1 / 1;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      overflow: hidden;
      position: relative;
    }
    .content-card img, .content-card video {
      width: 100%; height: 100%;
      object-fit: cover;
    }
    .reel-container {
      height: calc(100vh - var(--nav-height) - 100px);
      overflow-y: scroll;
      scroll-snap-type: y mandatory;
      display: flex;
      flex-direction: column;
    }
    .reel-item {
      scroll-snap-align: start;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #000;
      position: relative;
      border-bottom: 1px solid var(--border);
    }
    .reel-item video {
      width: 100%;
      height: auto;
      max-height: 100%;
    }
    .chat-messages {
      flex: 1;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 8px;
      padding: 8px 0;
      margin-bottom: 10px;
    }
    .msg {
      max-width: 70%;
      padding: 10px 14px;
      border-radius: 18px;
      background: var(--surface);
      border: 1px solid var(--border);
      font-size: 14px;
      line-height: 1.3;
      align-self: flex-start;
    }
    .msg.own {
      align-self: flex-end;
      background: #fff;
      color: #000;
      border: none;
    }
    .chat-input-area {
      display: flex;
      gap: 8px;
    }
    .modal-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.8);
      z-index: 200;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    .modal-overlay.active { display: flex; }
    .modal-box {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 24px;
      width: 100%;
      max-width: 400px;
      display: flex;
      flex-direction: column;
      gap: 14px;
    }
    .date-selectors {
      display: flex;
      gap: 8px;
    }
    .date-selectors select {
      flex: 1;
      background: var(--bg);
      border: 1px solid var(--border);
      color: var(--text);
      padding: 10px;
      border-radius: var(--radius);
    }
    .file-label {
      border: 1px dashed var(--border);
      padding: 16px;
      text-align: center;
      cursor: pointer;
      border-radius: var(--radius);
      transition: 0.2s;
    }
    .file-label:hover { border-color: #fff; }
    hr { border: 0.5px solid var(--border); margin: 10px 0; }
    .small-text { font-size: 13px; color: var(--muted); }
    .search-input { margin-bottom: 10px; }
  </style>
</head>
<body>

  <!-- HEADER (app) -->
  <div class="header" id="appHeader" style="display:none;">
    <div class="logo">DAZER</div>
    <div class="header-actions">
      <span style="font-size:14px;" id="headerUsername"></span>
      <span class="status-dot" id="headerStatusDot" style="background:var(--online);"></span>
      <button class="icon-btn" id="logoutBtn" title="Cerrar sesion">X</button>
    </div>
  </div>

  <!-- LOGIN SCREEN -->
  <div id="loginScreen" class="screen active">
    <div class="login-box">
      <h3 style="text-align:center; letter-spacing:3px;">INICIAR SESION</h3>
      <input type="text" class="input" id="loginUsername" placeholder="Nombre de usuario" autocomplete="off">
      <input type="password" class="input" id="loginPass" placeholder="Contrasena">
      <button class="btn" id="loginBtn">ENTRAR</button>
      <div class="error-msg" id="loginError">Credenciales incorrectas</div>
      <hr>
      <button class="btn secondary" id="openMasterPanelBtn">CREAR CUENTA (Admin)</button>
    </div>
  </div>

  <!-- MASTER PANEL MODAL (crear cuenta) -->
  <div class="modal-overlay" id="masterModal">
    <div class="modal-box">
      <h3 style="letter-spacing:2px;">CREAR CUENTA NUEVA</h3>
      <input type="password" class="input" id="masterCodeInput" placeholder="Codigo maestro">
      <button class="btn" id="verifyMasterBtn">VERIFICAR</button>
      <div class="error-msg" id="masterError">Codigo incorrecto</div>
      <div id="createForm" style="display:none; flex-direction:column; gap:12px;">
        <input type="text" class="input" id="newUsername" placeholder="Nombre de usuario">
        <div class="date-selectors">
          <select id="daySelect"></select>
          <select id="monthSelect"></select>
          <select id="yearSelect"></select>
        </div>
        <input type="password" class="input" id="newPassword" placeholder="Contrasena del usuario">
        <button class="btn" id="createUserBtn">CREAR USUARIO</button>
        <div class="error-msg" id="createError">Completa todos los campos</div>
      </div>
      <button class="btn secondary" id="closeMasterModal">CANCELAR</button>
    </div>
  </div>

  <!-- MAIN APP -->
  <div id="mainApp" style="display:none; flex:1; flex-direction:column;">
    <!-- Navegar Screen -->
    <div id="navegarScreen" class="screen active">
      <div class="grid" id="contentGrid"></div>
    </div>
    <!-- Reels Screen -->
    <div id="reelsScreen" class="screen">
      <div class="reel-container" id="reelContainer"></div>
      <div style="padding:8px; text-align:center;">
        <label class="file-label" for="reelUploadInput">Subir reel (video)</label>
        <input type="file" id="reelUploadInput" accept="video/*" style="display:none;" onchange="uploadReel()">
      </div>
    </div>
    <!-- Chat Screen -->
    <div id="chatScreen" class="screen">
      <input type="text" class="input search-input" id="chatSearchUser" placeholder="Buscar usuario para chatear...">
      <div id="chatUserList" style="margin-bottom:10px;"></div>
      <div id="chatWindow" style="display:none; flex:1; flex-direction:column;">
        <div class="chat-messages" id="chatMessages"></div>
        <div class="chat-input-area">
          <input type="text" class="input" id="chatInput" placeholder="Mensaje..." style="flex:1;">
          <button class="btn" id="sendMsgBtn" style="padding:10px 16px;">ENVIAR</button>
        </div>
      </div>
    </div>
    <!-- Perfil Screen -->
    <div id="perfilScreen" class="screen">
      <div style="background:var(--surface); padding:16px; border-radius:var(--radius); margin-bottom:16px;">
        <p><strong>Usuario:</strong> <span id="profileUsername"></span></p>
        <p><strong>Email:</strong> <span id="profileEmail"></span></p>
        <p><strong>Nacimiento:</strong> <span id="profileBirth"></span></p>
      </div>
      <label class="file-label" for="stickerUploadInput">Subir sticker (imagen)</label>
      <input type="file" id="stickerUploadInput" accept="image/*" style="display:none;" onchange="uploadSticker()">
      <hr>
      <p class="small-text">Tus stickers:</p>
      <div class="grid" id="profileStickers"></div>
    </div>
    <!-- IA Screen (placeholder) -->
    <div id="iaScreen" class="screen">
      <div style="margin:auto; text-align:center; color:var(--muted);">
        <p style="font-size:48px; letter-spacing:2px;">[ IA ]</p>
        <p>Proximamente...</p>
      </div>
    </div>
    <!-- Haiku (Premium) Screen -->
    <div id="haikuScreen" class="screen">
      <div style="margin:auto; text-align:center; color:var(--muted);">
        <p style="font-size:48px; letter-spacing:2px;">[ HAIKU ]</p>
        <p>Zona premium</p>
      </div>
    </div>

    <!-- NAV BAR -->
    <div class="nav-bar">
      <button class="nav-item active" data-screen="navegarScreen">NAVEGAR</button>
      <button class="nav-item" data-screen="reelsScreen">REELS</button>
      <button class="nav-item" data-screen="chatScreen">CHAT</button>
      <button class="nav-item" data-screen="perfilScreen">PERFIL</button>
      <button class="nav-item" data-screen="iaScreen">IA</button>
      <button class="nav-item" data-screen="haikuScreen">HAIKU</button>
    </div>
  </div>

<script>
  // ==================== DAZER ENGINE ====================
  const STORAGE = 'dazer_db';
  const MASTER_CODE = '29112009';

  // DB structure
  let DB = {
    users: {},       // key: username, value: { username, password, birth, email, stickers:[], reels:[], online:false }
    chats: {},       // key: "user1|user2" (sorted), value: [ {from, text, time} ]
    globalReels: [], // all reels from all users (for browse) { username, videoDataUrl }
  };

  let currentUser = null; // logged in username

  function saveDB() { localStorage.setItem(STORAGE, JSON.stringify(DB)); }
  function loadDB() {
    let saved = localStorage.getItem(STORAGE);
    if (saved) {
      try { DB = JSON.parse(saved); } catch(e) { resetDB(); }
    } else { resetDB(); }
  }
  function resetDB() {
    DB = { users: {}, chats: {}, globalReels: [] };
    saveDB();
  }

  // ==================== UTILS ====================
  function showError(id, msg) {
    let el = document.getElementById(id);
    el.textContent = msg;
    el.style.display = 'block';
    setTimeout(() => el.style.display = 'none', 3000);
  }

  // ==================== LOGIN & MASTER ====================
  document.getElementById('loginBtn').addEventListener('click', () => {
    let username = document.getElementById('loginUsername').value.trim();
    let pass = document.getElementById('loginPass').value.trim();
    if (!username || !pass) return;
    if (DB.users[username] && DB.users[username].password === pass) {
      loginUser(username);
    } else {
      showError('loginError', 'Usuario o contrasena incorrectos');
    }
  });

  function loginUser(username) {
    currentUser = username;
    DB.users[username].online = true;
    // set other users offline (simulate)
    for (let u in DB.users) {
      if (u !== username) DB.users[u].online = false;
    }
    saveDB();
    document.getElementById('loginScreen').classList.remove('active');
    document.getElementById('appHeader').style.display = 'flex';
    document.getElementById('mainApp').style.display = 'flex';
    document.getElementById('headerUsername').textContent = username;
    document.getElementById('headerStatusDot').style.background = 'var(--online)';
    updateAllUI();
    showScreen('navegarScreen');
  }

  document.getElementById('logoutBtn').addEventListener('click', () => {
    if (currentUser && DB.users[currentUser]) {
      DB.users[currentUser].online = false;
      saveDB();
    }
    currentUser = null;
    document.getElementById('loginScreen').classList.add('active');
    document.getElementById('appHeader').style.display = 'none';
    document.getElementById('mainApp').style.display = 'none';
    document.getElementById('loginUsername').value = '';
    document.getElementById('loginPass').value = '';
  });

  // Master panel
  document.getElementById('openMasterPanelBtn').addEventListener('click', () => {
    document.getElementById('masterModal').classList.add('active');
    document.getElementById('masterCodeInput').value = '';
    document.getElementById('createForm').style.display = 'none';
  });
  document.getElementById('closeMasterModal').addEventListener('click', () => {
    document.getElementById('masterModal').classList.remove('active');
  });
  document.getElementById('verifyMasterBtn').addEventListener('click', () => {
    if (document.getElementById('masterCodeInput').value === MASTER_CODE) {
      document.getElementById('createForm').style.display = 'flex';
      populateDateSelectors();
    } else {
      showError('masterError', 'Codigo maestro incorrecto');
    }
  });

  function populateDateSelectors() {
    let daySel = document.getElementById('daySelect');
    let monthSel = document.getElementById('monthSelect');
    let yearSel = document.getElementById('yearSelect');
    daySel.innerHTML = '';
    monthSel.innerHTML = '';
    yearSel.innerHTML = '';
    for (let i=1; i<=31; i++) daySel.innerHTML += `<option value="${i}">${i}</option>`;
    let months = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];
    months.forEach((m, idx) => monthSel.innerHTML += `<option value="${idx+1}">${m}</option>`);
    let currentYear = new Date().getFullYear();
    for (let y=currentYear; y>=currentYear-100; y--) yearSel.innerHTML += `<option value="${y}">${y}</option>`;
  }

  document.getElementById('createUserBtn').addEventListener('click', () => {
    let username = document.getElementById('newUsername').value.trim();
    let password = document.getElementById('newPassword').value.trim();
    let day = document.getElementById('daySelect').value;
    let month = document.getElementById('monthSelect').value;
    let year = document.getElementById('yearSelect').value;
    if (!username || !password || !day || !month || !year) {
      showError('createError', 'Completa todos los campos');
      return;
    }
    if (DB.users[username]) {
      showError('createError', 'Ese usuario ya existe');
      return;
    }
    let birth = `${day}/${month}/${year}`;
    let email = `${username}@dazerpost.com`;
    DB.users[username] = {
      username,
      password,
      birth,
      email,
      stickers: [],
      reels: [],
      online: false
    };
    saveDB();
    document.getElementById('newUsername').value = '';
    document.getElementById('newPassword').value = '';
    document.getElementById('createForm').style.display = 'none';
    showError('createError', ''); // clear
    alert('Usuario creado exitosamente');
    document.getElementById('masterModal').classList.remove('active');
  });

  // ==================== NAVIGATION ====================
  document.querySelectorAll('.nav-item').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.nav-item').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      let screenId = btn.dataset.screen;
      showScreen(screenId);
    });
  });

  function showScreen(id) {
    document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
    document.getElementById(id).classList.add('active');
    if (id === 'navegarScreen') renderBrowseGrid();
    if (id === 'reelsScreen') renderReels();
    if (id === 'chatScreen') renderChatUserList();
    if (id === 'perfilScreen') renderProfile();
  }

  // ==================== PERFIL & STICKERS ====================
  function renderProfile() {
    if (!currentUser) return;
    let user = DB.users[currentUser];
    document.getElementById('profileUsername').textContent = user.username;
    document.getElementById('profileEmail').textContent = user.email;
    document.getElementById('profileBirth').textContent = user.birth;
    let stickersContainer = document.getElementById('profileStickers');
    stickersContainer.innerHTML = '';
    if (user.stickers.length) {
      user.stickers.forEach((dataUrl, idx) => {
        let card = document.createElement('div');
        card.className = 'content-card';
        let img = document.createElement('img');
        img.src = dataUrl;
        card.appendChild(img);
        stickersContainer.appendChild(card);
      });
    } else {
      stickersContainer.innerHTML = '<p class="small-text">Sin stickers</p>';
    }
  }

  function uploadSticker() {
    let file = document.getElementById('stickerUploadInput').files[0];
    if (!file || !currentUser) return;
    let reader = new FileReader();
    reader.onload = function(e) {
      DB.users[currentUser].stickers.push(e.target.result);
      saveDB();
      renderProfile();
      renderBrowseGrid(); // update navegar too
    };
    reader.readAsDataURL(file);
  }

  // ==================== REELS ====================
  function uploadReel() {
    let file = document.getElementById('reelUploadInput').files[0];
    if (!file || !currentUser) return;
    let reader = new FileReader();
    reader.onload = function(e) {
      let videoDataUrl = e.target.result;
      DB.globalReels.push({ username: currentUser, videoDataUrl });
      if (!DB.users[currentUser].reels) DB.users[currentUser].reels = [];
      DB.users[currentUser].reels.push(videoDataUrl);
      saveDB();
      renderReels();
      renderBrowseGrid();
    };
    reader.readAsDataURL(file);
  }

  function renderReels() {
    let container = document.getElementById('reelContainer');
    container.innerHTML = '';
    if (!DB.globalReels.length) {
      container.innerHTML = '<p class="small-text" style="text-align:center; margin-top:40px;">No hay reels aun</p>';
      return;
    }
    DB.globalReels.forEach((reel, idx) => {
      let item = document.createElement('div');
      item.className = 'reel-item';
      let video = document.createElement('video');
      video.src = reel.videoDataUrl;
      video.controls = true;
      video.loop = true;
      video.setAttribute('playsinline', '');
      item.appendChild(video);
      container.appendChild(item);
    });
  }

  // ==================== NAVEGAR (grid) ====================
  function renderBrowseGrid() {
    let grid = document.getElementById('contentGrid');
    grid.innerHTML = '';
    // combine all stickers from all users
    let allContent = [];
    for (let username in DB.users) {
      let user = DB.users[username];
      if (user.stickers) {
        user.stickers.forEach(dataUrl => allContent.push({ type: 'sticker', username, dataUrl }));
      }
    }
    // add reels thumbnails? just show first frame? we'll show video icon placeholder
    if (DB.globalReels.length) {
      DB.globalReels.forEach(reel => allContent.push({ type: 'reel', username: reel.username, dataUrl: reel.videoDataUrl }));
    }
    if (!allContent.length) {
      grid.innerHTML = '<p class="small-text">Contenido vacio</p>';
      return;
    }
    allContent.forEach(item => {
      let card = document.createElement('div');
      card.className = 'content-card';
      if (item.type === 'sticker') {
        let img = document.createElement('img');
        img.src = item.dataUrl;
        card.appendChild(img);
      } else {
        let video = document.createElement('video');
        video.src = item.dataUrl;
        video.muted = true;
        video.autoplay = true;
        video.loop = true;
        card.appendChild(video);
      }
      grid.appendChild(card);
    });
  }

  // ==================== CHAT ====================
  function renderChatUserList() {
    let listDiv = document.getElementById('chatUserList');
    let searchInput = document.getElementById('chatSearchUser');
    let filter = searchInput.value.trim().toLowerCase();
    listDiv.innerHTML = '';
    for (let username in DB.users) {
      if (username === currentUser) continue;
      if (filter && !username.toLowerCase().includes(filter)) continue;
      let user = DB.users[username];
      let card = document.createElement('div');
      card.className = 'user-card';
      card.innerHTML = `
        <div class="user-avatar">${username[0].toUpperCase()}</div>
        <div style="flex:1;">
          <strong>${username}</strong>
          <div><span class="status-dot" style="background:${user.online ? 'var(--online)' : 'var(--offline)'};"></span>${user.online ? 'En linea' : 'No en linea'}</div>
        </div>
      `;
      card.addEventListener('click', () => openChat(username));
      listDiv.appendChild(card);
    }
  }

  document.getElementById('chatSearchUser').addEventListener('input', renderChatUserList);

  function getChatKey(userA, userB) {
    return [userA, userB].sort().join('|');
  }

  function openChat(withUser) {
    document.getElementById('chatWindow').style.display = 'flex';
    document.getElementById('chatWindow').dataset.with = withUser;
    renderChatMessages(withUser);
  }

  function renderChatMessages(withUser) {
    let key = getChatKey(currentUser, withUser);
    let messages = DB.chats[key] || [];
    let container = document.getElementById('chatMessages');
    container.innerHTML = '';
    messages.forEach(msg => {
      let div = document.createElement('div');
      div.className = 'msg' + (msg.from === currentUser ? ' own' : '');
      div.textContent = msg.text;
      container.appendChild(div);
    });
    container.scrollTop = container.scrollHeight;
  }

  document.getElementById('sendMsgBtn').addEventListener('click', () => {
    let withUser = document.getElementById('chatWindow').dataset.with;
    if (!withUser) return;
    let text = document.getElementById('chatInput').value.trim();
    if (!text) return;
    let key = getChatKey(currentUser, withUser);
    if (!DB.chats[key]) DB.chats[key] = [];
    DB.chats[key].push({ from: currentUser, text, time: Date.now() });
    saveDB();
    document.getElementById('chatInput').value = '';
    renderChatMessages(withUser);
  });

  // ==================== LIVE UPDATES (polling simulation) ====================
  setInterval(() => {
    if (!currentUser) return;
    // refresh chat if chat window open
    let chatWindow = document.getElementById('chatWindow');
    if (chatWindow.style.display === 'flex') {
      let withUser = chatWindow.dataset.with;
      if (withUser) renderChatMessages(withUser);
    }
    // update own online status heartbeat (in real app would use server)
    // here just keep online true while logged in
  }, 2000);

  // ==================== INIT ====================
  window.addEventListener('load', () => {
    loadDB();
    // If user was logged in previously (but we don't store session, so start fresh)
    document.getElementById('loginScreen').classList.add('active');
    document.getElementById('appHeader').style.display = 'none';
    document.getElementById('mainApp').style.display = 'none';
    // pre-populate date selectors for master panel
    populateDateSelectors();
  });

  // Service worker registration for PWA
  if ('serviceWorker' in navigator) {
    window.addEventListener('load', () => {
      navigator.serviceWorker.register('data:application/javascript;base64,' + btoa(
        'self.addEventListener("fetch",e=>{e.respondWith(fetch(e.request))});' +
        'self.addEventListener("install",e=>{self.skipWaiting()});'
      )).catch(() => {});
    });
  }
</script>
</body>
</html>
